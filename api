export default async function handler(req, res) {
  res.setHeader('Access-Control-Allow-Origin', '*');
  res.setHeader('Access-Control-Allow-Methods', 'POST, OPTIONS');
  res.setHeader('Access-Control-Allow-Headers', 'Content-Type');
  if (req.method === 'OPTIONS') return res.status(200).end();
  if (req.method !== 'POST') return res.status(405).json({ error: 'Method not allowed' });

  const c = req.body;
  const prompt = `Analiza esta empresa objetivo para Kintai y responde SOLO con JSON válido sin markdown:

{"resumen_negocio":"máx 80 palabras: qué hace, a quién vende, cómo genera ingresos","signals":[{"nivel":"high|mid|low","titulo":"string corto","descripcion":"1-2 frases relevancia para Kintai"}],"apertura":"2-3 frases apertura natural no de vendedor"}

EMPRESA: ${c.name} | Sector: ${c.cnae} | Web: ${c.web||'nd'} | Empleados: ${c.employees||'?'} | ${c.city}, ${c.ccaa}
FINANCIERO: Ventas ${c.ventas}k€ (ant:${c.ventas_y1}) | EBITDA ${c.ebitda}k€ | Margen ${c.margen}% | Tesorería ${c.tesoreria}k€ | Deuda ${c.deuda}k€
CIRCULANTE: PMC ${c.pmc}d | PMP ${c.pmp}d | Gap ${c.gap}d | NOF ${c.nof}k€
Genera 3 señales. Apertura específica y natural.`;

  try {
    const r = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-api-key': process.env.ANTHROPIC_API_KEY,
        'anthropic-version': '2023-06-01'
      },
      body: JSON.stringify({
        model: 'claude-sonnet-4-6',
        max_tokens: 1000,
        system: 'Eres el SDR Copilot de Kintai, fintech española de anticipo de facturación y líneas de circulante. Ayudas a SDRs a preparar llamadas. Kintai resuelve tensiones de tesorería: empresas con cobros lentos, clientes en Administración Pública, ciclos largos, necesidad de liquidez sin afectar CIRBE. Responde SOLO en español, SOLO con JSON válido.',
        messages: [{ role: 'user', content: prompt }]
      })
    });
    const data = await r.json();
    const raw = data.content?.[0]?.text || '';
    const parsed = JSON.parse(raw.replace(/^```json\s*/, '').replace(/```\s*$/, '').trim());
    return res.status(200).json(parsed);
  } catch (e) {
    return res.status(500).json({ error: e.message });
  }
}
